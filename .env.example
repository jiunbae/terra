# 쉼표로 구분한 Gemini API 키. 하나만 쓰려면 GEMINI_API_KEY도 지원합니다.
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# 로컬 Apple Silicon 이미지 생성 (mflux 설치 후 활성화)
TERRA_IMAGE_COMMAND=mflux-generate-z-image-turbo
TERRA_IMAGE_MODEL=filipstrand/Z-Image-Turbo-mflux-4bit
TERRA_IMAGE_STEPS=9
# 기본값: planet/surface 1344x896, inhabitant 896x1152 (32px 배수로 보정)
TERRA_IMAGE_PLANET_WIDTH=1344
TERRA_IMAGE_PLANET_HEIGHT=896
TERRA_IMAGE_SURFACE_WIDTH=1344
TERRA_IMAGE_SURFACE_HEIGHT=896
TERRA_IMAGE_INHABITANT_WIDTH=896
TERRA_IMAGE_INHABITANT_HEIGHT=1152
# 절차적 비지구형 대륙 가이드가 최종 행성 구도에 미치는 영향 (0.15~0.75)
TERRA_PLANET_GUIDE_STRENGTH=0.52
# guidance를 지원하는 비-Turbo 모델로 교체할 때만 설정 (Turbo는 항상 0)
# TERRA_IMAGE_GUIDANCE=4
# 0은 이미 4-bit인 모델에 재양자화를 하지 않는다는 뜻입니다.
TERRA_IMAGE_QUANTIZE=0
TERRA_IMAGE_TIMEOUT=1200

# 고품질 모드의 최종 보정 뒤 선택적으로 실행할 외부 업스케일러입니다.
# {input}, {output}, {model} 자리표시자를 지원합니다. 비워 두면 1536px급
# 모델 재정제 결과를 그대로 사용합니다.
# TERRA_UPSCALER_COMMAND=realesrgan-ncnn-vulkan -i {input} -o {output} -n {model} -s 2
TERRA_UPSCALER_MODEL=realesrgan-x4plus
TERRA_UPSCALE_TIMEOUT=900

# 임시 공개 데모 보호: IP당 시간당 허용 횟수
TERRA_ANALYZE_RATE_LIMIT=12
TERRA_IMAGE_RATE_LIMIT=4
TERRA_IMAGE_GLOBAL_RATE_LIMIT=12
TERRA_SAVE_RATE_LIMIT=12
TERRA_ANALYZE_CONCURRENCY=3
TERRA_IMAGE_MAX_ACTIVE_JOBS=3
# fast=1, balanced=2, quality=4 work unit으로 계산합니다.
TERRA_IMAGE_MAX_WORK_UNITS=8
TERRA_IMAGE_QUEUE_RETRY_AFTER=120
TERRA_MIN_FREE_DISK_MB=2048
# DB에서 참조되지 않는 생성 PNG 보존/정리 정책
TERRA_GENERATED_TTL_HOURS=168
TERRA_GENERATED_CLEANUP_GRACE_MINUTES=60
TERRA_GENERATED_CLEANUP_INTERVAL_HOURS=6
# 0이면 전체 생성 이미지 용량 상한을 사용하지 않습니다.
TERRA_GENERATED_MAX_MB=0

# 프로덕션 HTTP 경계. 기본은 loopback입니다. 호스트의 별도 reverse proxy가
# LAN 인터페이스로 접근하는 배치에서는 .env.local에 해당 인터페이스 주소와
# 그 프록시 주소를 TERRA_HOST/TERRA_FORWARDED_ALLOW_IPS로 지정합니다.
TERRA_ENV=production
TERRA_HOST=127.0.0.1
TERRA_ALLOWED_HOSTS=terra.jiun.dev,localhost,127.0.0.1
TERRA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TERRA_FORWARDED_ALLOW_IPS=127.0.0.1
TERRA_MAX_REQUEST_BYTES=1048576
TERRA_HTTP_CONCURRENCY=128
TERRA_HTTP_BACKLOG=128
TERRA_GRACEFUL_SHUTDOWN_SECONDS=30
